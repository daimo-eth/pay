{
  "name": "@daimo/sdk",
  "version": "1.2.3-dev",
  "description": "Daimo SDK - universal ramp for stablecoin apps",
  "author": "Daimo",
  "license": "BSD-2-Clause",
  "type": "module",
  "exports": {
    "./common": {
      "import": "./dist/common/index.js",
      "types": "./dist/common/index.d.ts"
    },
    "./client": {
      "import": "./dist/client/index.js",
      "types": "./dist/client/index.d.ts"
    },
    "./web": {
      "import": "./dist/web/index.js",
      "types": "./dist/web/index.d.ts"
    },
    "./web/api": {
      "import": "./dist/web/api/index.js",
      "types": "./dist/web/api/index.d.ts"
    },
    "./web/styles.css": "./dist/web/styles.css",
    "./web/theme.css": "./dist/web/theme.css"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "tsc --watch --preserveWatchOutput & pnpm exec tailwindcss -i src/web/theme.css -o dist/web/theme.css --watch & wait",
    "build": "tsc && pnpm exec tailwindcss -i src/web/theme.css -o dist/web/theme.css --minify && cp dist/web/theme.css dist/web/styles.css && pnpm run verify:styles",
    "test": "pnpm run lint && pnpm run build",
    "lint": "eslint --max-warnings=0",
    "verify:styles": "node ./scripts/verifyStyles.mjs"
  },
  "dependencies": {
    "@privy-io/react-auth": "^3.17.0",
    "@scure/base": "^2.0.0",
    "@solana-program/system": "^0.12.0",
    "@solana-program/token": "^0.12.0",
    "@solana/kit": "^6.3.1",
    "@solana/wallet-standard-features": "^1.3.0",
    "@sumsub/websdk-react": "^2.6.1",
    "@wallet-standard/app": "^1.1.0",
    "@wallet-standard/features": "^1.1.0",
    "viem": "^2.47.5",
    "zod": "^3.24.2"
  },
  "peerDependencies": {
    "@solana/web3.js": "^1.95.4",
    "qrcode": "^1.5.0",
    "react": "18.x || 19.x",
    "react-dom": "18.x || 19.x"
  },
  "peerDependenciesMeta": {
    "react-dom": {
      "optional": true
    },
    "qrcode": {
      "optional": true
    },
    "@solana/web3.js": {
      "optional": true
    }
  },
  "devDependencies": {
    "@solana/web3.js": "^1.98.4",
    "@types/qrcode": "^1.4.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "postcss": "^8.5.6",
    "postcss-selector-parser": "^6.1.2",
    "tailwindcss": "^3.4.12",
    "typescript": "5.9.2"
  }
}
