{
  "name": "@daimo/sdk",
  "version": "1.0.2-dev",
  "description": "Daimo SDK - universal ramp for stablecoin apps",
  "author": "Daimo",
  "license": "BSD-2-Clause",
  "type": "module",
  "exports": {
    "./common": {
      "import": "./dist/common/index.js",
      "types": "./dist/common/index.d.ts"
    },
    "./client": {
      "import": "./dist/client/index.js",
      "types": "./dist/client/index.d.ts"
    },
    "./web": {
      "import": "./dist/web/index.js",
      "types": "./dist/web/index.d.ts"
    },
    "./web/api": {
      "import": "./dist/web/api/index.js",
      "types": "./dist/web/api/index.d.ts"
    },
    "./web/styles.css": "./dist/web/styles.css",
    "./web/theme.css": "./dist/web/theme.css"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "tsc --watch --preserveWatchOutput",
    "build": "tsc && cp src/web/theme.css dist/web/theme.css && npx tailwindcss -i src/web/styles.css -o dist/web/styles.css --minify",
    "test": "npm run lint",
    "lint": "eslint --max-warnings=0"
  },
  "dependencies": {
    "@scure/base": "^2.0.0",
    "@solana/wallet-standard-features": "^1.3.0",
    "@wallet-standard/app": "^1.1.0",
    "@wallet-standard/features": "^1.1.0",
    "viem": "^2.43.4",
    "zod": "^3.24.2"
  },
  "peerDependencies": {
    "@solana/web3.js": "^1.95.4",
    "qrcode": "^1.5.0",
    "react": "18.x || 19.x",
    "react-dom": "18.x || 19.x"
  },
  "peerDependenciesMeta": {
    "react-dom": {
      "optional": true
    },
    "qrcode": {
      "optional": true
    },
    "@solana/web3.js": {
      "optional": true
    }
  },
  "devDependencies": {
    "@solana/web3.js": "^1.98.4",
    "@types/qrcode": "^1.4.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "tailwindcss": "^3.4.12",
    "typescript": "5.9.2"
  }
}
